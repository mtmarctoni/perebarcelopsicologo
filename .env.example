# =============================================================================
# Environment Variable Template
# =============================================================================
# Copy this file to create per-environment configs:
#   cp .env.example .env              # local development
#   cp .env.example .env.production   # production values
#   cp .env.example .env.preview      # preview / staging values
#
# Or simply run:  npm run env:init
#
# SECURITY REMINDERS:
#   • NEVER commit .env files to git — they are gitignored by default.
#   • NEVER put secrets in NEXT_PUBLIC_* variables (they ship to the browser).
#   • Keep Resend API keys, passwords, and tokens in server-only variables.
# =============================================================================

# =============================================================================
# Server Environment Variables (Secret)
# =============================================================================
# These are used exclusively on the server and must NEVER be exposed to the browser.

# Resend API key for sending transactional emails.
# Get yours at: https://resend.com/api-keys
# Required for the contact form to work.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Search Console site verification code.
# Optional. Get yours at: https://search.google.com/search-console
GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port for local development server. Defaults to 3000.
# Usually only needed in .env (local), not in .env.production.
PORT=3000

# =============================================================================
# Client Environment Variables (Public)
# =============================================================================
# These are prefixed with NEXT_PUBLIC_ and are embedded into the client bundle at build time.
# Do NOT put secrets here — they will be visible in the browser.

# Public Calendly scheduling URL shown in the contact page.
# Optional — if omitted, the booking widget shows a friendly placeholder.
# Example: https://calendly.com/your-name/30min
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-name/30min
