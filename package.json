{
  "name": "perebarcelopsicologo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "pnpm format && pnpm lint && pnpm type-check && pnpm knip && pnpm test",
    "lint": "biome check . && node scripts/check-server-only-imports.mjs",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "env:pull": "vercel env pull .env.local",
    "env:push": "./scripts/vercel-env-push.sh",
    "knip": "knip",
    "seo:check": "./scripts/seo-check.sh",
    "lighthouse:check": "./scripts/lighthouse-check.sh",
    "gitpush": "git add . && git commit -m quickCommit && git push",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.9",
    "@swc/helpers": "^0.5.17",
    "framer-motion": "^12.0.1",
    "next": "^16.2.6",
    "next-intl": "^4.13.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "resend": "^4.1.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@svgr/webpack": "^8.1.0",
    "@types/node": "^20",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "knip": "^6.16.0",
    "lighthouse": "^13.4.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "overrides": {
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2"
  }
}
